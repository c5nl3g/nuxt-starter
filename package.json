{
  "name": "nuxt-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "deps:check": "pnpm dlx taze -r",
    "dev": "nuxt dev",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "generate": "nuxt generate",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "preview": "nuxt preview",
    "reset": "pnpm dlx rimraf -g '**/node_modules' '**/.nuxt' '**/pnpm-lock.yaml'"
  },
  "dependencies": {
    "nuxt": "^4.4.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
